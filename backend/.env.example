DJANGO_SECRET_KEY=replace-this-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,api.your-domain.com
DJANGO_CORS_ALLOWED_ORIGINS=https://your-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com
DJANGO_DB_PATH=./data/db.sqlite3
DJANGO_STATIC_ROOT=./staticfiles
DJANGO_MEDIA_ROOT=./media
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
OPENAI_API_KEY=sk-...
OPENAI_AGENT_MODEL=gpt-4.1-mini
OPENAI_RECEIPT_MODEL=gpt-4o-mini
